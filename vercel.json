{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "nodeVersion": "18.x",
  "env": {
    "VITE_API_URL": "@fre_api_url"
  },
  "envs": [
    {
      "key": "fre_api_url",
      "target": "production",
      "type": "secret",
      "description": "Render Backend API URL"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-app.onrender.com/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
